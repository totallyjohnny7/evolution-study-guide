var omiHTML='<div id="omi-lecture-block" style="padding:20px 24px;font-family:inherit;font-size:14px;line-height:1.85;color:#e8e4d8">'
+'<div class="omi-legend">Red border = from live lecture (Omi) | No border = from textbook</div>'
+'<h2 style="color:#d4a826;margin:1.2rem 0 .8rem;font-size:18px;font-weight:700;border-bottom:1px solid rgba(255,255,255,.07);padding-bottom:.4rem;letter-spacing:-.2px">LECTURE: Early Earth \x26 History of Life (April 1)</h2>'
+'<div class="omi-source" data-source="omi" data-lecture="2026-04-01" style="background:rgba(22,33,62,.6);border-radius:12px;padding:16px 18px;margin-bottom:12px">'
+'<h3 style="color:#5DCAA5;margin-bottom:.5rem;font-size:15px;font-weight:600">Age of the Earth \x26 Radiometric Dating</h3>'
+'<ul style="list-style:disc;padding-left:1.1rem;line-height:1.7;font-size:13.5px">'
+'<li>Earth is approximately <strong>4.568 billion years old</strong>, from a protoplanetary disc</li>'
+'<li><strong>Darwin estimated several billion years</strong> \u2014 geologist first, biologist second</li>'
+'<li><strong>Lord Kelvin: ~20M years</strong> \u2014 wrong (missed radioactive heat generation)</li>'
+'<li><strong>Radiometric dating</strong>: isotopes decay at constant rates into daughter isotopes</li>'
+'<li><strong>Half-life</strong>: 1 HL = 50%, 2 = 25%, 3 = 12.5%</li>'
+'<li><strong>C-14</strong>: ~5,700yr HL, up to ~50kyr. <strong>U-238</strong>: ~4.5 byr HL</li>'
+'<li><strong>Oldest zircon</strong>: 4.4 byr (W. Australia), cross-checked U-235 + U-238</li>'
+'</ul></div>'
+'<div class="omi-source" data-source="omi" data-lecture="2026-04-01" style="background:rgba(22,33,62,.6);border-radius:12px;padding:16px 18px;margin-bottom:12px">'
+'<h3 style="color:#F0997B;margin-bottom:.5rem;font-size:15px;font-weight:600">Origin of Life \x26 Endosymbiosis</h3>'
+'<ul style="list-style:disc;padding-left:1.1rem;line-height:1.7;font-size:13.5px">'
+'<li><strong>Earliest life: ~3.8 bya</strong> (biomarkers)</li>'
+'<li><strong>Amino acids from inorganic material</strong> (abiogenesis)</li>'
+'<li><strong>Endosymbiosis</strong>: archaean consumed bacterium \u2192 mitochondria; later \u2192 chloroplasts</li>'
+'<li><strong>Multicellularity evolved multiple times</strong>: fungi, animals, plants</li>'
+'</ul></div>'
+'<div class="omi-source" data-source="omi" data-lecture="2026-04-01" style="background:rgba(22,33,62,.6);border-radius:12px;padding:16px 18px;margin-bottom:12px">'
+'<h3 style="color:#AFA9EC;margin-bottom:.5rem;font-size:15px;font-weight:600">Geologic Time Periods</h3>'
+'<div style="background:rgba(175,169,236,.07);border-left:3px solid #AFA9EC;border-radius:4px;padding:8px 12px;margin:6px 0;font-size:12.5px"><strong style="color:#AFA9EC">MNEMONIC:</strong> <em>Come Over Some Day Maybe Play Poker</em> = Cambrian\u2192Permian</div>'
+'<div style="background:rgba(175,169,236,.07);border-left:3px solid #AFA9EC;border-radius:4px;padding:8px 12px;margin:6px 0;font-size:12.5px"><strong style="color:#AFA9EC">MNEMONIC:</strong> <em>Tried and Just Couldn\u2019t</em> = Triassic, Jurassic, Cretaceous</div>'
+'<ul style="list-style:disc;padding-left:1.1rem;line-height:1.7;font-size:13.5px;margin-top:.5rem">'
+'<li><strong>Ordovician</strong>: early bony fishes, first land plants</li>'
+'<li><strong>Silurian</strong>: first land animals (millipede-like arthropods)</li>'
+'<li><strong>Devonian</strong> (Age of Fishes): first tetrapods</li>'
+'<li><strong>Carboniferous</strong> (Age of Amphibians): coal deposits, gymnosperms</li>'
+'<li><strong>Permian</strong>: synapsids (\u2192mammals) split from diapsids (\u2192reptiles/dinosaurs/birds)</li>'
+'</ul></div>'
+'<div class="omi-source" data-source="omi" data-lecture="2026-04-01" style="background:rgba(22,33,62,.6);border-radius:12px;padding:16px 18px;margin-bottom:12px">'
+'<h3 style="color:#F09595;margin-bottom:.5rem;font-size:15px;font-weight:600">KT Extinction \x26 Cenozoic</h3>'
+'<ul style="list-style:disc;padding-left:1.1rem;line-height:1.7;font-size:13.5px">'
+'<li><strong>~65 mya</strong>: Chicxulub impact, ~2/3 species extinct</li>'
+'<li>Birds in dinosaurs ~150 mya. Dinosaurs ~230 mya. Fruit drove primate color vision</li>'
+'<li><strong>Cenozoic</strong>: mammals radiated into empty niches after KT</li>'
+'<li>Primates: small, arboreal. Apes ~20 mya. Hominins ~7 mya. <strong>H. sapiens ~200 kya</strong></li>'
+'</ul></div>'
+'<div class="omi-source" data-source="omi" data-lecture="2026-04-01" style="background:rgba(22,33,62,.6);border-radius:12px;padding:16px 18px;margin-bottom:12px">'
+'<h3 style="color:#85B7EB;margin-bottom:.5rem;font-size:15px;font-weight:600">Key Dates</h3>'
+'<table style="width:100%;border-collapse:collapse;font-size:13px">'
+'<tr style="border-bottom:1px solid rgba(255,255,255,.07)"><td style="padding:4px 6px;color:#FAC775;font-weight:600;width:90px">4.568 bya</td><td style="padding:4px 6px">Earth formed</td></tr>'
+'<tr style="border-bottom:1px solid rgba(255,255,255,.07)"><td style="padding:4px 6px;color:#FAC775;font-weight:600">4.4 bya</td><td style="padding:4px 6px">Oldest zircon</td></tr>'
+'<tr style="border-bottom:1px solid rgba(255,255,255,.07)"><td style="padding:4px 6px;color:#FAC775;font-weight:600">3.8 bya</td><td style="padding:4px 6px">Earliest life</td></tr>'
+'<tr style="border-bottom:1px solid rgba(255,255,255,.07)"><td style="padding:4px 6px;color:#FAC775;font-weight:600">~230 mya</td><td style="padding:4px 6px">First dinosaurs</td></tr>'
+'<tr style="border-bottom:1px solid rgba(255,255,255,.07)"><td style="padding:4px 6px;color:#FAC775;font-weight:600">~150 mya</td><td style="padding:4px 6px">Birds arise</td></tr>'
+'<tr style="border-bottom:1px solid rgba(255,255,255,.07)"><td style="padding:4px 6px;color:#FAC775;font-weight:600">~65 mya</td><td style="padding:4px 6px">KT extinction</td></tr>'
+'<tr style="border-bottom:1px solid rgba(255,255,255,.07)"><td style="padding:4px 6px;color:#FAC775;font-weight:600">~7 mya</td><td style="padding:4px 6px">Earliest hominins</td></tr>'
+'<tr><td style="padding:4px 6px;color:#FAC775;font-weight:600">~200 kya</td><td style="padding:4px 6px">Homo sapiens</td></tr>'
+'</table></div>'
+'</div>';

function injectOmi(){
  var m=document.querySelector('main.ct')||document.querySelector('main');
  if(!m)return;
  if(m.querySelector('#omi-lecture-block'))return;
  var d=document.createElement('div');
  d.innerHTML=omiHTML;
  m.appendChild(d.firstChild);
}

// Initial injection after app renders
setTimeout(injectOmi,600);

// Re-inject whenever <main> content changes (app navigation)
var obs=new MutationObserver(function(){
  setTimeout(injectOmi,100);
});
function startObserving(){
  var m=document.querySelector('main.ct')||document.querySelector('main');
  if(m){obs.observe(m,{childList:true});}
  else{setTimeout(startObserving,200);}
}
setTimeout(startObserving,700);
})();</script></body></html>